    {
      "parameters": {
        "operation": "getAll",
        "tableId": "Lease_Parse_Output",
        "returnAll": true,
        "filters": {
          "conditions": [
            {
              "keyName": "rent_due_day",
              "condition": "eq",
              "keyValue": "={{ new Date(Date.now() + 1*24*60*60*1000).toISOString().slice(0,10) }}\n"
            }
          ]
        }
      },
