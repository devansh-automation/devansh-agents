    {
      "parameters": {
        "jsCode": "const localContacts = $('Insert row1').all().map(item => ({\n  firstName: item.json.firstName || \"\",\n  lastName: item.json.lastName || \"\",\n  fullName: item.json.cleanName || \"\",\n  originalName: item.json.fullNameOriginal || \"\",\n  phone: String(item.json.mobile1 || '').replace(/\\D/g, ''),\n  leadSource: item.json.leadSource || \"\",\n  contactType: item.json.contactType || \"\",\n  companyName: item.json.companyName || \"\"\n}));\n\nconst zohoContacts = $('Get Zoho Contacts').all()\n  .filter(item => item.json.data && item.json.data.length > 0)\n  .flatMap(item =>\n    item.json.data.map(contact => ({\n      id: contact.id,\n      name: contact.Full_Name || \"\",\n      phone: (contact.Mobile || \"\").replace(/\\D/g, '')\n    }))\n  );\n\nconst results = [];\n\nfor (const lc of localContacts) {\n  const zohoMatch = zohoContacts.find(zc =>\n    (lc.phone && zc.phone && lc.phone === zc.phone) ||\n    (lc.fullName &&\n      zc.name &&\n      zc.name.toLowerCase().trim() === lc.fullName.toLowerCase().trim())\n  );\n\n  results.push({\n    json: {\n      status: zohoMatch ? \"matched\" : \"unmatched\",\n      localContact: lc,\n      zohoContact: zohoMatch || null\n    }\n  });\n}\n\nreturn results;"
      },
