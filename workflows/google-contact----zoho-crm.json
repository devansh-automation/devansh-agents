    {
      "parameters": {
        "jsCode": "const googleContacts = $('Fetch Google Contacts').all().map(item => ({\n  name: item.json.names?.[0]?.displayName || '',\n  normalizedPhone: item.json.phoneNumbers?.[0]?.value?.replace(/\\D/g, '') || ''\n}));\n\nconst zohoContacts = $('Fetch Zoho Contacts').all().map(item => ({\n  id: item.json.id,\n  name: item.json.Full_Name || '',\n  normalizedPhone: item.json.Phone?.replace(/\\D/g, '') || ''\n}));\n\nconst results = [];\n\nfor (const gc of googleContacts) {\n  const zohoMatch = zohoContacts.find(zc =>\n    (gc.normalizedPhone && zc.normalizedPhone && gc.normalizedPhone === zc.normalizedPhone) || // exact phone match\n    (gc.name && zc.name && zc.name.toLowerCase().includes(gc.name.toLowerCase()))              // name match\n  );\n\n  if (zohoMatch) {\n    results.push({\n      json: {\n        status: 'matched',\n        phoneMismatch: gc.normalizedPhone !== zohoMatch.normalizedPhone, // true = matched by name but phones differ\n        googleContact: gc,\n        zohoContact: zohoMatch\n      }\n    });\n  } else {\n    results.push({\n      json: {\n        status: 'unmatched',\n        googleContact: gc\n      }\n    });\n  }\n}\n\nreturn results;"
      },
