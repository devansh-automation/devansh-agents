    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const fullName = item.json.names?.displayName || \"\";\n  const lowerName = fullName.toLowerCase();\n\n  let leadSource = \"\";\n  let contactType = \"\";\n  let cleanName = fullName;\n\n  // Detect Lead Source\n  if (lowerName.includes(\"fiverr\")) {\n    leadSource = \"Fiverr\";\n  } else if (lowerName.includes(\"upwork\")) {\n    leadSource = \"Upwork\";\n  } else if (lowerName.includes(\"skype\")) {\n    leadSource = \"Skype\";\n  } else if (lowerName.includes(\"pph\")) {\n    leadSource = \"PPH\";\n  } else if (lowerName.includes(\"website\")) {\n    leadSource = \"Website\";\n  }\n\n  // Detect Contact Type\n  if (lowerName.includes(\"client\")) {\n    contactType = \"Client\";\n  }\n\n  // Clean name\n  cleanName = cleanName\n    .replace(/fiverr/gi, \"\")\n    .replace(/upwork/gi, \"\")\n    .replace(/skype/gi, \"\")\n    .replace(/pph/gi, \"\")\n    .replace(/website/gi, \"\")\n    .replace(/client/gi, \"\")\n    .replace(/\\(\\)/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n\n  // Split first + last name\n  const splitName = cleanName.split(\" \");\n  const firstName = splitName[0] || \"\";\n  const lastName = splitName.slice(1).join(\" \") || \"Unknown\";\n\n  // Get all available phone numbers\n  const allPhones = [\n    item.json.phoneNumbers?.mobile?.[0] || \"\",\n    item.json.phoneNumbers?.home?.[0] || \"\",\n    item.json.phoneNumbers?.work?.[0] || \"\",\n    item.json.phoneNumbers?.other?.[0] || \"\"\n  ].filter(phone => phone);\n\n  // Remove duplicate phone numbers while keeping first occurrence\n  const uniquePhones = [...new Set(allPhones)];\n\n  return {\n    json: {\n      contactId: item.json.contactId || \"\",\n\n      displayName: fullName,\n\n      firstName,\n      lastName,\n\n      contactType,\n      leadSource,\n\n      emails:\n        item.json.emailAddresses?.home?.[0] ||\n        item.json.emailAddresses?.work?.[0] ||\n        item.json.emailAddresses?.other?.[0] ||\n        \"\",\n\n      phoneNumbers: {\n        primaryPhone: uniquePhones[0] || \"\",\n        secondaryPhone: uniquePhones[1] || \"\"\n      },\n\n      addresses:\n        item.json.addresses?.[0]?.formattedValue ||\n        item.json.addresses?.[0]?.streetAddress ||\n        \"\",\n\n      organization:\n        item.json.organizations?.[0]?.name || \"\",\n\n      url:\n        item.json.urls?.[0]?.value || \"\",\n\n      occupation:\n        item.json.occupations?.[0]?.value || \"\"\n    }\n  };\n});"
      },
