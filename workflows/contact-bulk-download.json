    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO contacts (\n  id, first_name, last_name, email, duration,\n  industry_choice_1, industry_choice_2, industry_1_areas, industry_2_areas,\n  placement_status, role_success_stage, role_success_notes,\n  myinterview_url, link_to_cv, skills\n) VALUES (\n  {{$json[\"id\"]}}, {{$json[\"first_name\"]}}, {{$json[\"last_name\"]}}, {{$json[\"email\"]}}, {{$json[\"duration\"]}},\n  {{$json[\"industry_choice_1\"]}}, {{$json[\"industry_choice_2\"]}}, {{$json[\"industry_1_areas\"]}}, {{$json[\"industry_2_areas\"]}},\n  {{$json[\"placement_status\"]}}, {{$json[\"role_success_stage\"]}}, {{$json[\"role_success_notes\"]}},\n  {{$json[\"myinterview_url\"]}}, {{$json[\"link_to_cv\"]}}, {{$json[\"skills\"]}}\n)\nON DUPLICATE KEY UPDATE\n  first_name = {{$json[\"first_name\"]}},\n  last_name = {{$json[\"last_name\"]}},\n  email = {{$json[\"email\"]}},\n  duration = {{$json[\"duration\"]}},\n  industry_choice_1 = {{$json[\"industry_choice_1\"]}},\n  industry_choice_2 = {{$json[\"industry_choice_2\"]}},\n  industry_1_areas = {{$json[\"industry_1_areas\"]}},\n  industry_2_areas = {{$json[\"industry_2_areas\"]}},\n  placement_status = {{$json[\"placement_status\"]}},\n  role_success_stage = {{$json[\"role_success_stage\"]}},\n  role_success_notes = {{$json[\"role_success_notes\"]}},\n  myinterview_url = {{$json[\"myinterview_url\"]}},\n  link_to_cv = {{$json[\"link_to_cv\"]}},\n  skills = {{$json[\"skills\"]}};\n",
        "options": {
          "queryReplacement": ""
        }
      },
