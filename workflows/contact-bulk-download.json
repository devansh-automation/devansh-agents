    {
      "parameters": {
        "jsCode": "return items[0].json.data.map(contact => {\n  return {\n    json: {\n      id: contact.id,\n      first_name: contact.First_Name || null,\n      last_name: contact.Last_Name || null,\n      email: contact.Email || null,\n      duration: contact.Duration ? parseInt(contact.Duration) : null,\n      industry_choice_1: contact.Industry_Choice_1 || null,\n      industry_choice_2: contact.Industry_choice_2 || null,\n      industry_1_areas: contact.Industry_1_Areas || null,\n      industry_2_areas: contact.Industry_2_Areas || null,\n      placement_status: contact.Placement_status || null,\n      role_success_stage: contact.Role_Success_Stage || null,\n      role_success_notes: contact.Role_Success_Notes || null,\n      myinterview_url: contact.MyInterview_URL || null,\n      link_to_cv: contact.Link_to_CV || null,\n      skills: contact.Skills || null\n    }\n  };\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        520,
        -20
      ],
      "id": "440db2ba-82e1-4cfb-8b95-8992a5eae012",
      "name": "Code"
    },
    {
      "parameters": {
        "jsCode": "function escape(value) {\n  if (value === null || value === undefined) return 'NULL';\n  if (typeof value === 'number') return value;\n  return `'${value.replace(/'/g, \"''\")}'`;\n}\n\nreturn items.map(item => {\n  const c = item.json;\n  return {\n    json: {\n      id: escape(c.id),\n      first_name: escape(c.first_name),\n      last_name: escape(c.last_name),\n      email: escape(c.email),\n      duration: escape(c.duration),\n      industry_choice_1: escape(c.industry_choice_1),\n      industry_choice_2: escape(c.industry_choice_2),\n      industry_1_areas: escape(c.industry_1_areas),\n      industry_2_areas: escape(c.industry_2_areas),\n      placement_status: escape(c.placement_status),\n      role_success_stage: escape(c.role_success_stage),\n      role_success_notes: escape(c.role_success_notes),\n      myinterview_url: escape(c.myinterview_url),\n      link_to_cv: escape(c.link_to_cv),\n      skills: escape(c.skills)\n    }\n  };\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
