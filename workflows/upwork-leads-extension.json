    {
      "parameters": {
        "promptType": "define",
        "text": "=Here is a conversation between a client and a freelancer from {{ $('Fetch leads').item.json.body.project_description }}.\n\nExtract a clean project description that can be saved in a CRM.\n\nConversation:\n\n{{ $json.body.project_description }}\n\nOutput only the project description.\nDo not include headings, bullet points, or explanations.",
        "messages": {
          "messageValues": [
            {
              "message": "=You are an assistant that extracts structured business information from client conversations.\n\nYour task:\n- Generate a professional CRM project description\n- Maximum length: 250 characters (strict limit)\n- If the description exceeds 250 characters, shorten it automatically\n- Do NOT explain or justify\n- Do NOT add greetings or filler text\n- Output ONLY the final description text\n\nThe description must:\n- Clearly state what the client wants\n- Mention tools/platforms if referenced\n- Mention scope and deliverables if available\n- Be neutral and professional\n"
            }
          ]
        },
        "batching": {}
