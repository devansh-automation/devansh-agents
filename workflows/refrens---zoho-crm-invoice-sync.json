      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst appId = 'scaleupally-fQavn';\n// const appSecret = 'J1lPpNlRF3y7DBzoofGOBV-H';\nconst privateKeyB64 = 'MIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQgRSunJaKB66aEHQnWDXfLuUgy8GzE/92GNBD4+G/lsHehRANCAAQ9pAoh0RYvYNB3vHhLgqWcXi+6Gqg0WhTuXdK7tnah2Phg0n+vONjiGyT/OdE3u5XMf0LsNegz5YEx4+1s4yzD';\n\nfunction b64url(s) {\n  return Buffer.from(s).toString('base64')\n    .replace(/=/g,'').replace(/\\+/g,'-').replace(/\\//g,'_');\n}\n\nconst header = b64url(JSON.stringify({ alg: 'ES256', typ: 'JWT' }));\nconst now = Math.floor(Date.now() / 1000);\nconst payload = b64url(JSON.stringify({\n  iss: appId,\n  aud: 'serana',\n  sub: appId,\n  auth: {\n    entity: 'app',\n    strategy: 'app-iss-app-token'\n  },\n  iat: now,\n  exp: now + 3600\n}));\n\nconst signingInput = header + '.' + payload;\nconst privateKey = crypto.createPrivateKey({\n  key: Buffer.from(privateKeyB64, 'base64'),\n  format: 'der',\n  type: 'pkcs8'\n});\nconst signature = crypto\n  .sign('sha256', Buffer.from(signingInput), { key: privateKey, dsaEncoding: 'ieee-p1363' })\n  .toString('base64')\n  .replace(/=/g,'').replace(/\\+/g,'-').replace(/\\//g,'_');\n\nreturn [{ json: { token: signingInput + '.' + signature } }];"
      },
